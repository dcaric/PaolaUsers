{
  "$comment": "JSON validation contract for POST /api/users.",
  "description": "Defines required fields, blocks unknown fields, and validates formats before persistence.",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "email",
    "first_name",
    "last_name",
    "avatar"
  ],
  "properties": {
    "email": {
      "type": "string",
      "minLength": 3,
      "$comment": "Use JSON Schema email format validation.",
      "format": "email"
    },
    "first_name": {
      "type": "string",
      "$comment": "Must be non-empty.",
      "minLength": 1
    },
    "last_name": {
      "type": "string",
      "$comment": "Must be non-empty.",
      "minLength": 1
    },
    "avatar": {
      "type": "string",
      "$comment": "Must be non-empty (URL/path or identifier).",
      "minLength": 1
    }
  }
}
